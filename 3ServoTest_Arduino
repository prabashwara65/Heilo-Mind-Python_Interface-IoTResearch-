#include <Servo.h>

Servo servo9; // MIRROR SERVO D9
Servo servo10; // ARM LEFT/RIGHT
Servo servo12; // ARM UP/DOWN

int angle9 = 20;
int angle10 = 45;
int angle12 = 65;

#define D9_MIN 10
#define D9_MAX 70
#define ARM_LEFT_RIGHT_MIN 40
#define ARM_LEFT_RIGHT_MAX 60
#define ARM_UP_DOWN_MIN 30
#define ARM_UP_DOWN_MAX 70

void setup() {
  Serial.begin(9600);
  servo9.attach(9);
  servo10.attach(10);
  servo12.attach(12);

  servo9.write(angle9);
  servo10.write(angle10);
  servo12.write(angle12);

  Serial.println("Servo Ready");
}

void loop() {
  if (Serial.available()) {
    String data = Serial.readStringUntil('\n');
    data.trim();

    if (data.length() > 0) {
      char buf[64];
      data.toCharArray(buf, sizeof(buf));

      int values[3] = {0, 0, 0};
      int index = 0;
      char *token = strtok(buf, " ,");

      while (token != NULL && index < 3) {
        values[index++] = atoi(token);
        token = strtok(NULL, " ,");
      }

      if (index == 3) {
        angle9 = constrain(values[0], D9_MIN, D9_MAX);
        angle10 = constrain(values[1], ARM_LEFT_RIGHT_MIN, ARM_LEFT_RIGHT_MAX);
        angle12 = constrain(values[2], ARM_UP_DOWN_MIN, ARM_UP_DOWN_MAX);

        servo9.write(angle9);
        servo10.write(angle10);
        servo12.write(angle12);

        Serial.print(angle9);
        Serial.print(" ");
        Serial.print(angle10);
        Serial.print(" ");
        Serial.println(angle12);
      } else if (index == 2) {
        angle10 = constrain(values[0], ARM_LEFT_RIGHT_MIN, ARM_LEFT_RIGHT_MAX);
        angle12 = constrain(values[1], ARM_UP_DOWN_MIN, ARM_UP_DOWN_MAX);

        servo10.write(angle10);
        servo12.write(angle12);

        Serial.print(angle10);
        Serial.print(" ");
        Serial.println(angle12);
      }
    }

    // flush the rest of the line
    Serial.read(); 
  }
}
