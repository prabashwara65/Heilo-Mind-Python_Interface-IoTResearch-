#include <DHT.h>
#include <Wire.h>
#include <BH1750.h>
#include <Adafruit_GFX.h>
#include <Adafruit_SSD1306.h>
#include <Servo.h>

// ================= SENSOR PINS =================
#define DHTPIN A2
#define DHTTYPE DHT22
#define SOLAR_PIN A1
#define BATTERY_PIN A3

// ================= BATTERY CALIBRATION =================
// Voltage divider: R1=10kΩ, R2=3.3kΩ (adjust based on your circuit)
// Formula: V_battery = V_read * ((R1+R2)/R2)
// For 10k and 3.3k: (10000+3300)/3300 = 4.03
#define VOLTAGE_DIVIDER_RATIO 4.03f
#define ADC_REFERENCE 5.0f

// ================= OBJECTS =================
DHT dht(DHTPIN, DHTTYPE);
BH1750 lightMeter;

// ================= OLED =================
#define SCREEN_WIDTH 128
#define SCREEN_HEIGHT 64
#define OLED_RESET -1
Adafruit_SSD1306 display(SCREEN_WIDTH, SCREEN_HEIGHT, &Wire, OLED_RESET);
bool oledWorking = false;

// ================= SERVOS =================
Servo servo9;
Servo servo10;
Servo servo11;
Servo servo12;

// Current servo positions
int angle9 = 20;
int angle10 = 40;
int angle11 = 40;
int angle12 = 30;

// Servo limits
#define MIRROR_UP_DOWN_MIN 20
#define MIRROR_UP_DOWN_MAX 70
#define MIRROR_LEFT_RIGHT_MIN 40
#define MIRROR_LEFT_RIGHT_MAX 100
#define ARM_LEFT_RIGHT_MIN 40
#define ARM_LEFT_RIGHT_MAX 60
#define ARM_UP_DOWN_MIN 30
#define ARM_UP_DOWN_MAX 70

// ================= TIMING =================
unsigned long lastSensorRead = 0;
const unsigned long SENSOR_INTERVAL = 1000;

// ================= SENSOR VALUES =================
float temp = 0;
float hum = 0;
float lux = 0;
float solarVolt = 0;
float batteryVolt = 0;
float batteryCurrent = 0.02; // Estimated base current in Amps

// ================= SETUP =================
void setup() {

  Serial.begin(9600);
  delay(2000); // Increased delay for serial stability

  Serial.println("Arduino Starting...");

  dht.begin();
  Wire.begin();

  // BH1750
  if (!lightMeter.begin()) {
    Serial.println("BH1750 not found");
  }

  // OLED
  oledWorking = display.begin(SSD1306_SWITCHCAPVCC, 0x3C);
  if (!oledWorking) oledWorking = display.begin(SSD1306_SWITCHCAPVCC, 0x3D);

  if (oledWorking) {
    display.clearDisplay();
    display.setTextSize(1);
    display.setTextColor(WHITE);
    display.setCursor(0,0);
    display.println("System Booting...");
    display.display();
  }

  // Servos
  servo9.attach(9);
  servo10.attach(10);
  servo11.attach(11);
  servo12.attach(12);

  servo9.write(angle9);
  servo10.write(angle10);
  servo11.write(angle11);
  servo12.write(angle12);

  Serial.println("System Ready");
}

// ================= BATTERY VOLTAGE (ACCURATE) =================
float readBatteryVoltage() {
  int rawValue = analogRead(BATTERY_PIN);
  float voltageAtPin = (rawValue / 1023.0) * ADC_REFERENCE;
  float actualVoltage = voltageAtPin * VOLTAGE_DIVIDER_RATIO;
  
  // Add debug for first few readings
  static int debugCount = 0;
  if (debugCount++ < 5) {
    Serial.print("DEBUG: Raw=");
    Serial.print(rawValue);
    Serial.print(", PinV=");
    Serial.print(voltageAtPin, 3);
    Serial.print(", BattV=");
    Serial.println(actualVoltage, 2);
  }
  
  return actualVoltage;
}

// ================= ESTIMATE CURRENT DRAW =================
float estimateCurrentDraw() {
  float current = 0.015; // Base current for Arduino + sensors (15mA)
  
  // DHT22 current: ~1mA when reading
  current += 0.001;
  
  // BH1750 current: ~0.2mA
  current += 0.0002;
  
  // Servo current draw (when active)
  // Each servo draws ~10-50mA when idle, 200-500mA when moving
  // We'll estimate based on recent movement
  static unsigned long lastServoMove[4] = {0,0,0,0};
  unsigned long now = millis();
  
  // Check if servos have moved recently (within last 2 seconds)
  if (now - lastServoMove[0] < 2000) current += 0.05;  // Servo9
  if (now - lastServoMove[1] < 2000) current += 0.05;  // Servo10
  if (now - lastServoMove[2] < 2000) current += 0.05;  // Servo11
  if (now - lastServoMove[3] < 2000) current += 0.05;  // Servo12
  
  // OLED current: ~20mA when on
  if (oledWorking) current += 0.020;
  
  return current;
}

// ================= SENSOR FUNCTION =================
void readSensors()
{
  temp = dht.readTemperature();
  hum = dht.readHumidity();
  lux = lightMeter.readLightLevel();

  if (isnan(temp) || isnan(hum)) {
    temp = 0;
    hum = 0;
  }

  int rawSolar = analogRead(SOLAR_PIN);
  solarVolt = rawSolar * (5.0 / 1023.0);

  // Read accurate battery voltage
  batteryVolt = readBatteryVoltage();
  
  // Estimate current draw
  batteryCurrent = estimateCurrentDraw();
}

// ================= OLED DISPLAY =================
void updateOLED()
{
  if (!oledWorking) return;

  display.clearDisplay();

  display.setCursor(0,0);
  display.print("T:");
  display.print(temp,1);
  display.print("C");

  display.setCursor(60,0);
  display.print("H:");
  display.print(hum,1);

  display.setCursor(0,15);
  display.print("Lux:");
  display.print(lux);

  display.setCursor(0,30);
  display.print("Solar:");
  display.print(solarVolt,2);

  display.setCursor(0,45);
  display.print("Batt:");
  display.print(batteryVolt,2);
  display.print("V");

  display.display();
}

// ================= SEND BATTERY DATA (PYTHON FORMAT) =================
void sendBatteryData() {
  // Format: voltage,current,time
  Serial.print(batteryVolt, 3);  // Voltage with 3 decimal places
  Serial.print(",");
  Serial.print(batteryCurrent, 4); // Current with 4 decimal places
  Serial.print(",");
  Serial.println(millis());  // Time in milliseconds
}

// ================= SEND ALL SENSOR DATA (DEBUG/OTHER SYSTEMS) =================
void sendAllData()
{
  // ---- SERVOS FIRST ----
  Serial.print("SERVO9:");
  Serial.print(angle9);
  Serial.print(",");

  Serial.print("SERVO10:");
  Serial.print(angle10);
  Serial.print(",");

  Serial.print("SERVO11:");
  Serial.print(angle11);
  Serial.print(",");

  Serial.print("SERVO12:");
  Serial.print(angle12);
  Serial.print(",");

  // ---- SENSOR DATA AFTER ----
  Serial.print("TEMP:");
  Serial.print(temp,1);
  Serial.print(",");

  Serial.print("HUM:");
  Serial.print(hum,1);
  Serial.print(",");

  Serial.print("LUX:");
  Serial.print(lux);
  Serial.print(",");

  Serial.print("SOLAR:");
  Serial.print(solarVolt,2);
  Serial.print(",");

  Serial.print("BATT:");
  Serial.print(batteryVolt,2);
  Serial.print(",");
  
  Serial.print("CURRENT:");
  Serial.print(batteryCurrent,3);
  Serial.println();
}

// ================= LOOP =================
void loop() {

  unsigned long currentMillis = millis();

  // SENSOR READ AND DATA SEND
  if (currentMillis - lastSensorRead >= SENSOR_INTERVAL) {

    lastSensorRead = currentMillis;

    readSensors();

    updateOLED();
    
    // Send battery data in Python-compatible format (FIRST)
    sendBatteryData();
    
    // Send detailed sensor data (SECOND) - can be ignored by Python
    sendAllData();
  }

  // SERVO CONTROL
  if (Serial.available()) {

    String data = Serial.readStringUntil('\n');
    data.trim();
    
    // Store move times for current estimation
    static unsigned long lastServoMove[4] = {0,0,0,0};
    unsigned long now = millis();

    int values[4];
    int index = 0;
    int lastPos = 0;

    for (int i=0;i<data.length();i++) {

      if (data.charAt(i)==',' || i==data.length()-1) {

        String value;

        if (i==data.length()-1)
          value = data.substring(lastPos,i+1);
        else
          value = data.substring(lastPos,i);

        values[index++] = value.toInt();
        lastPos = i+1;
      }
    }

    if (index==4)
    {
      // Check if any servo angle changed
      bool servosMoved = false;
      if (values[0] != angle9 || values[1] != angle10 || 
          values[2] != angle11 || values[3] != angle12) {
        servosMoved = true;
      }
      
      angle9 = constrain(values[0], MIRROR_UP_DOWN_MIN, MIRROR_UP_DOWN_MAX);
      angle10 = constrain(values[1], ARM_LEFT_RIGHT_MIN, ARM_LEFT_RIGHT_MAX);
      angle11 = constrain(values[2], MIRROR_LEFT_RIGHT_MIN, MIRROR_LEFT_RIGHT_MAX);
      angle12 = constrain(values[3], ARM_UP_DOWN_MIN, ARM_UP_DOWN_MAX);

      servo9.write(angle9);
      servo10.write(angle10);
      servo11.write(angle11);
      servo12.write(angle12);
      
      // Record movement times
      if (servosMoved) {
        lastServoMove[0] = now;
        lastServoMove[1] = now;
        lastServoMove[2] = now;
        lastServoMove[3] = now;
      }

      // Re-read sensors and update after servo movement
      readSensors();
      updateOLED();
      
      // Send updated data
      sendBatteryData();
      sendAllData();
    }
  }
}
