# ARDUINO MANAGER - UPDATED FOR 3 SERVOS
# =============================
class ArduinoManager:
    """Manages Arduino serial communication for mirror control - 3 Servos (D10, D12, D9)"""
    
    def __init__(self):
        self.arduino = None
        self.port = Config.ARDUINO_PORT
        self.baud_rate = Config.ARDUINO_BAUD_RATE
        self.running = False
        self.serial_thread = None
        self.servo_queue = Queue(maxsize=1)
        
        # Global variables from Arduino (3 servos)
        self.D10_GLOBAL = Config.D10_INITIAL
        self.D12_GLOBAL = Config.D12_INITIAL
        self.D9_GLOBAL = Config.D9_INITIAL
        self.lock = threading.Lock()
        
    def connect(self) -> bool:
        """Connect to Arduino"""
        try:
            logger.info(f"🔌 Attempting to connect to Arduino on {self.port}...")
            self.arduino = serial.Serial(
                port=self.port,
                baudrate=self.baud_rate,
                timeout=Config.SERIAL_TIMEOUT
            )
            time.sleep(2)
            
            # Clear buffer
            while self.arduino.in_waiting:
                self.arduino.readline()
                
            logger.info(f"✅ Connected to Arduino on {self.port}")
            return True
            
        except Exception as e:
            logger.error(f"❌ Failed to connect to Arduino: {e}")
            return False
    
    def _serial_loop(self):
        """Background thread for serial communication - 3 servo values"""
        logger.debug("Serial communication thread started")
        while self.running:
            # Process servo commands
            try:
                angles = self.servo_queue.get(timeout=0.1)
                if angles is None:
                    logger.debug("Received stop signal for serial thread")
                    break
                    
                if self.arduino:
                    # Send 3 values: D10, D12, D9
                    cmd = f"{angles[0]},{angles[1]},{angles[2]}\n"
                    self.arduino.write(cmd.encode())
                    logger.info(f"📤 Sent: {cmd.strip()}")
                    
            except Empty:
                pass
            
            # Read Arduino data - expecting: "angle9,angle10,angle12"
            if self.arduino and self.arduino.in_waiting:
                try:
                    line = self.arduino.readline().decode().strip()
                    if line:
                        logger.debug(f"📥 Received: {line}")
                        
                        # Skip debug messages
                        if line.startswith("DEBUG") or line.startswith("RECV"):
                            continue
                        
                        parts = line.split(',')
                        if len(parts) >= 3:
                            with self.lock:
                                try:
                                    # Arduino sends: D9, D10, D12
                                    self.D9_GLOBAL = int(parts[0])
                                    self.D10_GLOBAL = int(parts[1])
                                    self.D12_GLOBAL = int(parts[2])
                                    logger.debug(f"📊 Updated: D9={self.D9_GLOBAL}, D10={self.D10_GLOBAL}, D12={self.D12_GLOBAL}")
                                except ValueError:
                                    logger.warning(f"Failed to parse: {parts}")
                except Exception as e:
                    logger.error(f"❌ Error reading Arduino: {e}")
            
            time.sleep(0.01)
    
    def start(self):
        """Start serial communication thread"""
        self.running = True
        self.serial_thread = Thread(target=self._serial_loop, daemon=True)
        self.serial_thread.start()
        logger.info("📡 Serial communication started")
    
    def stop(self):
        """Stop serial communication"""
        logger.info("Stopping serial communication...")
        self.running = False
        if self.serial_thread:
            self.servo_queue.put(None)
            self.serial_thread.join(timeout=5)
        
        if self.arduino:
            self.arduino.close()
            logger.info("✅ Disconnected from Arduino")
    
    def send_servo_command(self, d10: int, d12: int, d9: int):
        """Send 3-servo command to Arduino - ORDER: D10, D12, D9"""
        # Constrain values
        d10 = np.clip(d10, Config.D10_MIN, Config.D10_MAX)
        d12 = np.clip(d12, Config.D12_MIN, Config.D12_MAX)
        d9 = np.clip(d9, Config.D9_MIN, Config.D9_MAX)
        
        angles = [d10, d12, d9]
        
        if self.servo_queue.full():
            try:
                old = self.servo_queue.get_nowait()
                logger.debug(f"Dropped old command: {old}")
            except Empty:
                pass
        self.servo_queue.put(angles)
        logger.info(f"📤 Queued: D10={d10}, D12={d12}, D9={d9}")
    
    def send_initial_positions(self):
        """Send initial positions to Arduino"""
        logger.info("Sending initial positions...")
        self.send_servo_command(Config.D10_INITIAL, Config.D12_INITIAL, Config.D9_INITIAL)
        time.sleep(0.5)
    
    def get_positions(self) -> Dict[str, int]:
        """Get current servo positions"""
        with self.lock:
            return {
                "D10": self.D10_GLOBAL,
                "D12": self.D12_GLOBAL,
                "D9": self.D9_GLOBAL
            }

