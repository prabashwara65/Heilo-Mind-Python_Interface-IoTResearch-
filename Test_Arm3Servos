# LIGHT TRACKER
# =============================
class LightTracker:
    """Handles light tracking with camera - controls mirror servo (D9) only"""
    
    def __init__(self, arduino_manager: ArduinoManager):
        self.arduino = arduino_manager
        self.cap = None
        self.running = False
        self.tracker_thread = None
        self.position_history = deque(maxlen=Config.POSITION_HISTORY)
        self.current_mirror = Config.MIRROR_INITIAL
        self.target_mirror = Config.MIRROR_INITIAL
        self.last_servo_update = time.time()
        
    def find_camera(self, max_index: int = 3) -> bool:
        """Find and initialize camera"""
        logger.info("🔍 Looking for camera...")
        for i in range(max_index):
            logger.debug(f"Trying camera index {i}")
            cap = cv2.VideoCapture(i)
            if cap.isOpened():
                cap.set(cv2.CAP_PROP_FRAME_WIDTH, 320)
                cap.set(cv2.CAP_PROP_FRAME_HEIGHT, 240)
                cap.set(cv2.CAP_PROP_BUFFERSIZE, 1)
                self.cap = cap
                logger.info(f"✅ Camera found at index {i}")
                return True
            cap.release()
        logger.error("❌ No camera found")
        return False
    
    def map_value(self, val: float, old_min: float, old_max: float, new_min: float, new_max: float) -> int:
        """Map value from one range to another"""
        mapped = int((val - old_min) / (old_max - old_min) * (new_max - new_min) + new_min)
        return mapped
    
    def smooth_move(self, current: int, target: int) -> int:
        """Smooth servo movement"""
        diff = target - current
        step = np.clip(diff, -Config.MAX_SERVO_STEP, Config.MAX_SERVO_STEP)
        return int(current + step)
    
    def _tracking_loop(self):
        """Main tracking loop - controls mirror servo (D9) only"""
        logger.info("Tracking loop started")
        while self.running:
            if self.cap is None:
                time.sleep(0.1)
                continue
                
            ret, frame = self.cap.read()
            if not ret:
                time.sleep(0.01)
                continue
            
            h, w, _ = frame.shape
            gray = cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY)
            _, mask = cv2.threshold(gray, Config.BRIGHTNESS_THRESHOLD, 255, cv2.THRESH_BINARY)
            coords = cv2.findNonZero(mask)
            
            avg_cx = None
            
            if coords is not None:
                cx = int(coords[:, :, 0].mean())
                self.position_history.append(cx)
                avg_cx = int(sum(self.position_history) / len(self.position_history))
                mirror_angle = self.map_value(avg_cx, 0, w, Config.TRACKING_MIN, Config.TRACKING_MAX)
                self.target_mirror = np.clip(mirror_angle, Config.TRACKING_MIN, Config.TRACKING_MAX)
            
            now = time.time()
            if now - self.last_servo_update > Config.SERVO_UPDATE_INTERVAL:
                self.current_mirror = self.smooth_move(self.current_mirror, self.target_mirror)
                positions = self.arduino.get_servo_positions()
                self.arduino.send_servo_command(positions["D10"], positions["D12"], self.current_mirror)
                self.last_servo_update = now
                
                if Config.DEBUG and self.running:
                    light_pos = f"x={avg_cx}" if coords is not None else "None"
                    logger.info(f"Mirror: {self.current_mirror}° | Light: {light_pos}")
            
            time.sleep(0.001)
    
    def start_tracking(self) -> bool:
        """Start light tracking"""
        logger.info("🔦 Starting light tracking...")
        if not self.find_camera():
            return False
        
        self.running = True
        self.tracker_thread = Thread(target=self._tracking_loop, daemon=True)
        self.tracker_thread.start()
        logger.info("✅ Light tracking started")
        return True
    
    def stop_tracking(self):
        """Stop light tracking"""
        logger.info("Stopping light tracking...")
        self.running = False
        if self.tracker_thread:
            self.tracker_thread.join(timeout=5)
        if self.cap:
            self.cap.release()
        positions = self.arduino.get_servo_positions()
        self.arduino.send_servo_command(positions["D10"], positions["D12"], 90)
        logger.info("✅ Light tracking stopped")
    
    def get_status(self) -> Dict[str, Any]:
        """Get current tracking status"""
        positions = self.arduino.get_servo_positions()
        return {
            "tracking_active": self.running,
            "current_mirror": self.current_mirror,
            "target_mirror": self.target_mirror,
            "servo_positions": positions
        }

