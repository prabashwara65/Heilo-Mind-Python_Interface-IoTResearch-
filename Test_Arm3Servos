#include <Servo.h>

Servo servo9;   // MIRROR ROTATION (Pin D9)
Servo servo10;  // ARM LEFT/RIGHT (Pin D10)
Servo servo12;  // ARM UP/DOWN (Pin D12)

int angle9 = 10;
int angle10 = 45;
int angle12 = 65;

#define D9_MIN 0
#define D9_MAX 180
#define D10_MIN 40
#define D10_MAX 60
#define D12_MIN 30
#define D12_MAX 70

void setup() {
  Serial.begin(9600);
  servo9.attach(9);
  servo10.attach(10);
  servo12.attach(12);
  
  servo9.write(angle9);
  servo10.write(angle10);
  servo12.write(angle12);
  
  Serial.println("READY");
}

void loop() {
  if (Serial.available()) {
    int d10 = Serial.parseInt();
    int d12 = Serial.parseInt();
    int d9 = Serial.parseInt();
    
    if (d10 != 0) {
      angle10 = constrain(d10, D10_MIN, D10_MAX);
      servo10.write(angle10);
    }
    if (d12 != 0) {
      angle12 = constrain(d12, D12_MIN, D12_MAX);
      servo12.write(angle12);
    }
    if (d9 != 0) {
      angle9 = constrain(d9, D9_MIN, D9_MAX);
      servo9.write(angle9);
    }
    
    // Send back: D9, D10, D12
    Serial.print(angle9);
    Serial.print(",");
    Serial.print(angle10);
    Serial.print(",");
    Serial.println(angle12);
    
    while (Serial.available()) Serial.read();
  }
}
