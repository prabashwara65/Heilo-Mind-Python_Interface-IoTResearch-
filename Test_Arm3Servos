# MQTT SERVER
# =============================
class MirrorControlServer:
    """Handles incoming MQTT requests"""
    
    def __init__(self, arduino_manager: ArduinoManager, light_tracker: LightTracker, detector: ObjectDetectionManager):
        self.arduino = arduino_manager
        self.tracker = light_tracker
        self.detector = detector
        self.mqtt_client = None
        self.running = False
        self.request_queue = queue.Queue(maxsize=Config.REQUEST_QUEUE_SIZE)
        self.worker_threads = []
        self.dynamodb = None
        self.table = None
        self.request_count = 0
        self.request_lock = threading.Lock()
        
        if Config.ENABLE_DYNAMODB:
            try:
                self.dynamodb = boto3.resource("dynamodb", region_name=Config.REGION)
                self._ensure_table_exists()
            except Exception as e:
                logger.warning(f"⚠️ DynamoDB init failed: {e}")
    
    def _ensure_table_exists(self):
        if not self.dynamodb:
            return
        try:
            existing_tables = self.dynamodb.meta.client.list_tables()['TableNames']
            if Config.TABLE_NAME not in existing_tables:
                self.dynamodb.create_table(
                    TableName=Config.TABLE_NAME,
                    KeySchema=[{'AttributeName': 'requestId', 'KeyType': 'HASH'}],
                    AttributeDefinitions=[{'AttributeName': 'requestId', 'AttributeType': 'S'}],
                    BillingMode='PAY_PER_REQUEST'
                ).wait_until_exists()
            self.table = self.dynamodb.Table(Config.TABLE_NAME)
        except Exception as e:
            logger.error(f"Table error: {e}")
    
    def connect(self) -> bool:
        """Connect to AWS IoT Core"""
        try:
            logger.info("📡 Connecting to AWS IoT Core...")
            
            self.mqtt_client = AWSIoTMQTTClient(Config.SERVER_CLIENT_ID)
            self.mqtt_client.configureEndpoint(Config.AWS_IOT_ENDPOINT, 8883)
            self.mqtt_client.configureCredentials(
                str(Config.SERVER_ROOT_CA),
                str(Config.SERVER_PRIVATE_KEY),
                str(Config.SERVER_CERT)
            )
            
            if self.mqtt_client.connect():
                self.mqtt_client.subscribe(Config.REQUEST_TOPIC, 1, self._message_callback)
                logger.info("✅ Connected to AWS IoT Core")
                return True
            return False
        except Exception as e:
            logger.error(f"Connection failed: {e}")
            return False
    
    def _message_callback(self, client, userdata, message):
        """Handle incoming MQTT messages"""
        try:
            payload_str = message.payload.decode('utf-8')
            payload = json.loads(payload_str)
            
            request_id = payload.get('requestId', 'unknown')
            command = payload.get('command', '').lower()
            
            logger.info(f"📩 Received command: {command} (ID: {request_id})")
            
            self.request_queue.put({
                'payload': payload,
                'timestamp': time.time(),
                'request_id': request_id,
                'command': command
            })
        except Exception as e:
            logger.error(f"Message callback error: {e}")
    
    def _process_request(self, request: Dict[str, Any]):
        """Process a request"""
        start_time = time.time()
        payload = request['payload']
        request_id = request['request_id']
        command = request['command']
        
        result = {}
        
        try:
            if command == 'set_servos':
                d10 = payload.get('d10')
                d12 = payload.get('d12')
                d9 = payload.get('d9')
                
                if d10 is not None and d12 is not None and d9 is not None:
                    self.arduino.send_servo_command(d10, d12, d9)
                    result = {"command": "set_servos", "status": "ok"}
                else:
                    result = {"command": "set_servos", "status": "error", "message": "Missing values"}
            
            elif command == 'mirror_only':
                d9 = payload.get('d9', 10)
                self.arduino.send_single_mirror_command(d9)
                result = {"command": "mirror_only", "status": "ok", "mirror_angle": d9}
            
            elif command == 'center':
                self.arduino.send_servo_command(45, 55, 90)
                result = {"command": "center", "status": "ok"}
            
            elif command == 'start_tracking':
                if self.tracker.start_tracking():
                    result = {"command": "start_tracking", "status": "started"}
                else:
                    result = {"command": "start_tracking", "status": "failed"}
            
            elif command == 'stop_tracking':
                self.tracker.stop_tracking()
                result = {"command": "stop_tracking", "status": "stopped"}
            
            elif command == 'run_prediction':
                if not self.detector.get_status()['running']:
                    if self.tracker.running:
                        self.tracker.stop_tracking()
                    detection_result = self.detector.run_detection()
                    result = {"command": "run_prediction", "detection_result": detection_result}
                else:
                    result = {"command": "run_prediction", "status": "already_running"}
            
            elif command == 'stop_prediction':
                stop_result = self.detector.stop_detection()
                result = {"command": "stop_prediction", "stop_result": stop_result}
            
            elif command == 'get_status':
                result = {
                    "command": "get_status",
                    "servo_positions": self.arduino.get_servo_positions(),
                    "tracking": self.tracker.get_status(),
                    "detection": self.detector.get_status()
                }
            
            else:
                result = {"command": command, "status": "unknown"}
            
            processing_time = time.time() - start_time
            
            response = {
                "requestId": request_id,
                "timestamp": time.time(),
                "processing_time_seconds": processing_time,
                "result": result
            }
            
            self.mqtt_client.publish(Config.RESPONSE_TOPIC, json.dumps(response), 1)
            self.mqtt_client.publish(Config.CLIENT_PUBLISH_TOPIC, json.dumps(response), 1)
            
            logger.info(f"✅ Response sent for {request_id} in {processing_time:.2f}s")
            
            if self.dynamodb and self.table:
                try:
                    response['timestamp_str'] = datetime.now().isoformat()
                    self.table.put_item(Item=convert_floats_to_decimal(response))
                except Exception as e:
                    logger.error(f"DynamoDB error: {e}")
                    
        except Exception as e:
            logger.error(f"Process request error: {e}")
    
    def _worker_thread(self, thread_id: int):
        """Worker thread"""
        while self.running:
            try:
                request = self.request_queue.get(timeout=1)
                self._process_request(request)
                self.request_queue.task_done()
            except Empty:
                continue
            except Exception as e:
                logger.error(f"Worker error: {e}")
    
    def start(self) -> bool:
        if not self.connect():
            return False
        
        self.running = True
        for i in range(Config.NUM_WORKER_THREADS):
            thread = Thread(target=self._worker_thread, args=(i,), daemon=True)
            thread.start()
            self.worker_threads.append(thread)
        
        logger.info(f"🚀 Server started with {Config.NUM_WORKER_THREADS} workers")
        return True
    
    def stop(self):
        self.running = False
        for thread in self.worker_threads:
            thread.join(timeout=2)
        if self.mqtt_client:
            self.mqtt_client.disconnect()

# =============================
# MAIN APPLICATION
# =============================
class MirrorControlApp:
    """Main application"""
    
    def __init__(self):
        self.arduino = ArduinoManager()
        self.tracker = LightTracker(self.arduino)
        self.detector = ObjectDetectionManager()
        self.server = None
        self.running = False
    
    def initialize(self) -> bool:
        logger.info("=" * 60)
        logger.info("🪞 MIRROR CONTROL SYSTEM - INITIALIZING")
        logger.info("=" * 60)
        
        if not self.arduino.connect():
            logger.warning("⚠️ Arduino not connected")
        
        self.arduino.start()
        self.arduino.send_initial_positions()
        
        self.server = MirrorControlServer(self.arduino, self.tracker, self.detector)
        
        logger.info("✅ SYSTEM INITIALIZED")
        return True
    
    def start(self):
        if not self.server.start():
            logger.error("Failed to start server")
            return
        
        self.running = True
        self._print_system_info()
        
        try:
            while self.running:
                time.sleep(1)
        except KeyboardInterrupt:
            self.stop()
    
    def stop(self):
        logger.info("🛑 Shutting down...")
        self.running = False
        self.tracker.stop_tracking()
        self.detector.stop_detection()
        if self.server:
            self.server.stop()
        self.arduino.stop()
        logger.info("✅ Shutdown complete")
    
    def _print_system_info(self):
        logger.info("=" * 60)
        logger.info("📊 SYSTEM INFORMATION")
        logger.info("=" * 60)
        logger.info(f"📡 Listening on: {Config.REQUEST_TOPIC}")
        logger.info(f"📤 Publishing to: {Config.RESPONSE_TOPIC}")
        logger.info(f"🎮 Servo defaults: D10=45°, D12=65°, D9=10°")
        logger.info("=" * 60)
        logger.info("Press Ctrl+C to shutdown")
        logger.info("=" * 60)

