# OBJECT DETECTION MANAGER
# =============================
class ObjectDetectionManager:
    """Manages running the object detection script"""
    
    def __init__(self):
        self.process = None
        self.running = False
        self.stop_requested = False
        self.process_lock = threading.Lock()
        
    def check_script_exists(self) -> bool:
        return Config.OBJECT_DETECTION_SCRIPT.exists()
    
    def get_script_path(self) -> str:
        return str(Config.OBJECT_DETECTION_SCRIPT)
    
    def stop_detection(self) -> Dict[str, Any]:
        """Stop the running detection process"""
        logger.info("🛑 STOP DETECTION REQUEST RECEIVED")
        
        with self.process_lock:
            self.stop_requested = True
            if not self.running or not self.process:
                return {"success": True, "message": "No detection running"}
            
            try:
                parent = psutil.Process(self.process.pid)
                children = parent.children(recursive=True)
                for child in children:
                    child.kill()
                parent.kill()
                parent.wait(timeout=3)
                self.process = None
                self.running = False
                return {"success": True, "process_stopped": True}
            except Exception as e:
                return {"success": False, "error": str(e)}
    
    def run_detection(self, timeout: int = 60) -> Dict[str, Any]:
        """Run object detection script"""
        logger.info("🔍 OBJECT DETECTION REQUEST RECEIVED")
        
        with self.process_lock:
            if self.running and self.process:
                return {"success": False, "error": "Detection already running"}
            self.stop_requested = False
        
        if not self.check_script_exists():
            return {"success": False, "error": "Script not found"}
        
        try:
            os.chmod(self.get_script_path(), 0o755)
            start_time = time.time()
            
            with self.process_lock:
                self.process = subprocess.Popen(
                    [sys.executable, self.get_script_path()],
                    stdout=subprocess.PIPE,
                    stderr=subprocess.PIPE,
                    text=True,
                    cwd=str(Config.ROOT_DIR),
                    preexec_fn=os.setsid
                )
                self.running = True
            
            while self.running and not self.stop_requested:
                if self.process.poll() is not None:
                    stdout, stderr = self.process.communicate(timeout=1)
                    execution_time = time.time() - start_time
                    
                    with self.process_lock:
                        self.running = False
                        self.process = None
                    
                    if self.process.returncode == 0:
                        return {
                            "success": True,
                            "execution_time_seconds": execution_time,
                            "output": stdout[-500:] if stdout else ""
                        }
                    else:
                        return {"success": False, "error": stderr}
                
                time.sleep(0.5)
            
            return {
                "success": False,
                "error": "Stopped by user",
                "stopped_early": True
            }
            
        except Exception as e:
            with self.process_lock:
                self.running = False
                self.process = None
            return {"success": False, "error": str(e)}
    
    def get_status(self) -> Dict[str, Any]:
        with self.process_lock:
            return {
                "running": self.running,
                "stop_requested": self.stop_requested,
                "process_active": self.process is not None
            }

